# Variables de entorno del backend
# Copiar este archivo como .env y rellenar los valores

# Secreto para firmar los tokens JWT — usar una cadena larga y aleatoria en producción
JWT_SECRET=cambiar_este_secreto_en_produccion

# Puerto del servidor
PORT=3000

# Cadena de conexión PostgreSQL
# Desarrollo local: postgresql://usuario:password@localhost:5432/sia_db
# Railway: se inyecta automáticamente al vincular el plugin PostgreSQL
DATABASE_URL=postgresql://usuario:password@localhost:5432/sia_db

# Entorno (development | production)
NODE_ENV=development
